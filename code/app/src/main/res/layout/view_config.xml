<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface">

    <LinearLayout
        style="@style/vbox"
        android:padding="16dp">

        <LinearLayout
            style="@style/hbox"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/text_mode"
                style="@style/title"
                android:text="Config" />
            <View style="@style/spacer" />
            <ImageButton
                android:id="@+id/button_menu"
                style="@style/icon"
                android:src="@drawable/icon_menu"
                android:contentDescription="Menu" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            style="@style/card"
            android:layout_marginTop="16dp">

            <LinearLayout
                style="@style/vbox"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp">

                <Spinner
                    android:id="@+id/select_pack_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minHeight="48dp" />

                <Spinner
                    android:id="@+id/select_img_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minHeight="48dp" />

                <Spinner
                    android:id="@+id/select_enc_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minHeight="48dp" />

                <CheckBox
                    android:id="@+id/check_inmem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="In-Mem View" />

                <Button
                    android:id="@+id/button_save_config"
                    style="@style/btnPri"
                    android:layout_width="match_parent"
                    android:layout_marginTop="16dp"
                    android:text="Save Settings" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/card"
            android:layout_marginTop="16dp">

            <LinearLayout
                style="@style/vbox"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp">

                <EditText
                    android:id="@+id/edit_pubkey"
                    style="@style/body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Paste Public Key"
                    android:minLines="3"
                    android:gravity="top"
                    android:background="?attr/colorSurface"
                    android:padding="8dp"
                    android:inputType="textMultiLine"
                    android:autofillHints="none" />

                <Spinner
                    android:id="@+id/select_pubkey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minHeight="48dp" />

                <LinearLayout
                    style="@style/hbox"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/button_add_pubkey"
                        style="@style/btnPri"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Add Pub" />

                    <View android:layout_width="8dp" android:layout_height="0dp" />
                    <Button
                        android:id="@+id/button_del_pubkey"
                        style="@style/btnDan"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Delete Pub" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/card"
            android:layout_marginTop="16dp">

            <LinearLayout
                style="@style/vbox"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp">

                <LinearLayout style="@style/hbox">
                    <Button
                        android:id="@+id/button_select_file"
                        style="@style/btnSec"
                        android:layout_width="wrap_content"
                        android:text="Select File" />
                    <TextView
                        android:id="@+id/text_file_status"
                        style="@style/body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="No file selected"
                        android:ellipsize="end"
                        android:maxLines="1" />
                </LinearLayout>

                <Spinner
                    android:id="@+id/select_kf"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minHeight="48dp" />

                <LinearLayout
                    style="@style/hbox"
                    android:layout_marginTop="8dp">
                    <Button
                        android:id="@+id/button_add_kf"
                        style="@style/btnPri"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Add KF" />
                    <View android:layout_width="8dp" android:layout_height="0dp" />
                    <Button
                        android:id="@+id/button_del_kf"
                        style="@style/btnDan"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Delete KF" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/card"
            android:layout_marginTop="16dp">

            <LinearLayout
                style="@style/hbox"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:gravity="top">

                <LinearLayout
                    style="@style/vbox"
                    android:layout_width="0dp"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/edit_pubkey_content"
                        style="@style/body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:minLines="3"
                        android:background="?attr/colorSurface"
                        android:padding="8dp"
                        android:text="Pubkey data..." />

                    <TextView
                        android:id="@+id/edit_privkey_content"
                        style="@style/body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:minLines="3"
                        android:background="?attr/colorSurface"
                        android:padding="8dp"
                        android:text="Privkey data..." />
                </LinearLayout>

                <LinearLayout
                    style="@style/vbox"
                    android:layout_width="wrap_content"
                    android:layout_marginStart="8dp"
                    android:gravity="center_horizontal">
                    <ImageButton
                        android:id="@+id/button_view"
                        style="@style/icon"
                        android:src="@drawable/icon_view"
                        android:contentDescription="View" />
                    <ImageButton
                        android:id="@+id/button_download"
                        style="@style/icon"
                        android:src="@drawable/icon_download"
                        android:contentDescription="Download" />
                    <ImageButton
                        android:id="@+id/button_edit"
                        style="@style/icon"
                        android:src="@drawable/icon_edit"
                        android:contentDescription="Modify" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/text_status"
            style="@style/body"
            android:layout_width="match_parent"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="64dp"
            android:maxLines="3"
            android:ellipsize="end"
            android:text="Encrypt\nStatus\nReady..." />
    </LinearLayout>
</ScrollView>